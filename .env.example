# ---------------------------------------------------------------------------
# Database (Neon or Supabase Postgres)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host:5432/iconcrm?sslmode=require"

# ---------------------------------------------------------------------------
# Auth (NextAuth / Auth.js — Microsoft Entra ID / Azure AD)
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# When "true", enables a dev-only email/password credentials login so the app
# can be exercised without a real Azure tenant. NEVER enable in production.
DEV_AUTH_ENABLED="true"

# ---------------------------------------------------------------------------
# Inbound email capture (Postmark Inbound)
# ---------------------------------------------------------------------------
POSTMARK_INBOUND_TOKEN="shared-secret-checked-on-webhook"

# ---------------------------------------------------------------------------
# Outbound email (Resend)
# ---------------------------------------------------------------------------
RESEND_API_KEY=""
RESEND_FROM_EMAIL="ops@ourdomain.com"

# ---------------------------------------------------------------------------
# File storage (Vercel Blob)
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------------
# Cron (Vercel Cron) — shared secret checked on cron API routes
# ---------------------------------------------------------------------------
CRON_SECRET="shared-secret-checked-on-cron-routes"

# Base URL used in outbound links (magic links, etc.)
APP_BASE_URL="http://localhost:3000"

# Secret used to sign stateless magic-link tokens (missing-info forms, snooze).
TOKEN_SIGNING_SECRET="generate-with: openssl rand -base64 32"
